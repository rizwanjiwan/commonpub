{
  "name": "rizwanjiwan/commonpub",
  "version": "3.0.4",
  "type": "package",
  "description": "Common code for my projects",
  "license": "GPL-3.0-or-later",
  "require": {
    "simonbackx/slack-php-webhook": "^1.0",
    "monolog/monolog": "3.*",
    "jenssegers/blade": "^2",
    "giggsey/libphonenumber-for-php": "9.*",
    "league/oauth2-client": "2.*",
    "microsoft/microsoft-graph": "1.*",
    "league/oauth2-google":"5.*",
    "phpmailer/phpmailer": "7.*",
    "pda/pheanstalk": "8.*",
    "nesbot/carbon": "3.*",
    "sentry/sdk": "^3.0",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-ctype": "*"
  },
  "autoload": {
    "psr-4": {
      "rizwanjiwan\\common\\": "src"
    }
  },
  "config": {
    "platform": {
      "php": "8.3"
    },
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
